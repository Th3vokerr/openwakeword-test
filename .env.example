DISCORD_TOKEN=put-your-bot-token-here
BOT_PREFIX=!
PYTHON=.venv/bin/python
WAKEWORD=alexa
WAKEWORD_THRESHOLD=0.5
WAKEWORD_DEBOUNCE=1.5
SILENCE_MS=1100
SILENCE_RMS=450
MAX_RECORDING_MS=30000
DOWNLOAD_MODELS=0
TRANSCRIBE_RECORDINGS=1
NAGA_API_KEY=put-your-naga-api-key-here
NAGA_BASE_URL=https://api.naga.ac/v1
STT_MODEL=whisper-large-v3:free
STT_LANGUAGE=en
STT_PROMPT=Transcribe this as English Discord voice audio. Keep profanity as spoken.
DEBUG_LOGS=1
LEVEL_LOG_INTERVAL_MS=1000
